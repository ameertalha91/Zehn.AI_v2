/**
 * DATABASE SCHEMA - Zehn AI MVP
 *
 * Multi-role EdTech platform: Student, Instructor, ZehnAI super-user.
 *
 * KEY RELATIONSHIPS:
 * - Users belong to Centers/institutes (instructors)
 * - Students are PENDING_APPROVAL until an instructor approves them
 * - Classes belong to Centers; students enroll via Enrollment
 * - Assignments have FREE_TEXT or MCQ types; submissions are graded
 * - StudyPlans are created by instructors (AI-drafted) and published to students
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// USER MANAGEMENT
model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  password      String?      // Nullable — OAuth users may not have a password
  role          Role
  status        UserStatus   @default(PENDING_APPROVAL)
  centerId      String?
  image         String?      // Profile picture (OAuth)
  googleId      String?      @unique
  facebookId    String?      @unique
  loginAttempts Int          @default(0)
  lockedUntil   DateTime?
  classes       Enrollment[]
  messages      Message[]
  createdAt     DateTime     @default(now())
  Center        Center?      @relation(fields: [centerId], references: [id])
}

// CENTER MANAGEMENT
// Represents educational centers/institutions
model Center {
  id        String   @id @default(cuid())
  name      String   // Center name (e.g., "Zehn.AI CSS Academy")
  tutors    User[]   // Users who belong to this center
  classes   Class[]  // Courses offered by this center
  createdAt DateTime @default(now())
}

// COURSE MANAGEMENT
// Represents individual courses/classes
model Class {
  id          String       @id @default(cuid())
  name        String       // Course name
  description String?      // Course description
  maxStudents Int          @default(50) // Enrollment limit
  centerId    String       // Which center offers this course
  center      Center       @relation(fields: [centerId], references: [id])
  lectures    Lecture[]    // Course content (videos)
  quizzes     Quiz[]       // Course quizzes
  students    Enrollment[] // Student enrollments
  messages    Message[]    // Course chat messages
  assignments Assignment[] // Course assignments
  topicMappings CourseTopicMapping[] // Syllabus topics covered
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @default(now())
}

// ENROLLMENT MANAGEMENT
// Tracks which students are enrolled in which courses
model Enrollment {
  id        String   @id @default(cuid())
  userId    String   // Student ID
  classId   String   // Course ID
  user      User     @relation(fields: [userId], references: [id])
  klass     Class    @relation(fields: [classId], references: [id])
  role      String   // "student" or "tutor"
  createdAt DateTime @default(now())
}

// LECTURE MANAGEMENT
// Individual video lectures within a course
model Lecture {
  id         String   @id @default(cuid())
  classId    String   // Which course this lecture belongs to
  klass      Class    @relation(fields: [classId], references: [id])
  title      String   // Lecture title
  videoUrl   String?  // YouTube or video URL
  transcript String?  // Video transcript (optional)
  createdAt  DateTime @default(now())
}

model Quiz {
  id            String     @id @default(cuid())
  videoId       String
  video         Video      @relation(fields: [videoId], references: [id])
  questions     Json // Stores array of questions
  timeMarker    Int
  createdAt     DateTime   @default(now())
  classId       String?
  class         Class?     @relation(fields: [classId], references: [id])
  quizQuestions Question[] // Added missing relation
}

model Question {
  id        String @id @default(cuid())
  quizId    String
  quiz      Quiz   @relation(fields: [quizId], references: [id])
  prompt    String
  options   String // JSON string
  answerIdx Int
}

model MockExam {
  id        String     @id @default(cuid())
  userId    String
  classId   String?
  url       String // uploaded file path
  feedbacks Feedback[]
  createdAt DateTime   @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  mockId    String
  mock      MockExam @relation(fields: [mockId], references: [id])
  tutorId   String?
  rubric    String // JSON summary of scores
  comments  String?
  createdAt DateTime @default(now())
}

model StudyPlan {
  id           String    @id @default(cuid())
  studentId    String
  instructorId String
  classId      String?
  content      String    // JSON: { milestones, focusAreas, resources }
  aiDraft      Boolean   @default(false)
  published    Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// CSS SYLLABUS MANAGEMENT
// Tracks official CSS exam syllabus topics
model SyllabusTopic {
  id              String   @id @default(cuid())
  topicId         String   @unique // e.g., "pa-1.1"
  subject         String   // e.g., "pakistan-affairs"
  title           String   // Topic title
  description     String?  // Topic description
  parentTopicId   String?  // For subtopics
  priority        String   // high, medium, low
  estimatedHours  Int?     // Study hours needed
  orderIndex      Int      // For ordering topics
  createdAt       DateTime @default(now())
  
  // Relations
  courseMappings  CourseTopicMapping[]
}

// Maps courses to syllabus topics they cover
model CourseTopicMapping {
  id             String         @id @default(cuid())
  classId        String         // Course/Class ID
  topicId        String         // SyllabusTopic ID
  class          Class          @relation(fields: [classId], references: [id])
  syllabusTopic  SyllabusTopic  @relation(fields: [topicId], references: [id])
  coverageDepth  String?        // basic, intermediate, advanced
  createdAt      DateTime       @default(now())
  
  @@unique([classId, topicId])
}

model Message {
  id        String   @id @default(cuid())
  classId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])
  userId    String?
  Class     Class    @relation(fields: [classId], references: [id])
}

model Video {
  id        String   @id @default(cuid())
  youtubeId String   @unique
  title     String
  keywords  String   // JSON string for SQLite compatibility
  quizzes   Quiz[]
  createdAt DateTime @default(now())
}

model SampleQuestion {
  id       String @id @default(cuid())
  question String
  options  String // JSON string for SQLite compatibility
  correct  Int
  keywords String // JSON string for SQLite compatibility
  category String
}

model Assignment {
  id          String                 @id @default(cuid())
  title       String
  description String
  classId     String
  createdBy   String // Teacher who created it
  dueDate     DateTime
  maxPoints   Int                    @default(100)
  class       Class                  @relation(fields: [classId], references: [id])
  submissions AssignmentSubmission[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model AssignmentSubmission {
  id            String              @id @default(cuid())
  assignmentId  String
  studentId     String
  filePath      String // Path to uploaded PDF
  fileName      String // Original filename
  fileSize      Int // File size in bytes
  extractedText String? // OCR extracted text
  assignment    Assignment          @relation(fields: [assignmentId], references: [id])
  feedback      AssignmentFeedback?
  status        SubmissionStatus    @default(SUBMITTED)
  submittedAt   DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model AssignmentFeedback {
  id           String               @id @default(cuid())
  submissionId String               @unique
  teacherId    String // Teacher providing feedback
  grade        Int? // Grade out of max points
  comments     String? // Teacher comments
  rubricScores Json? // Detailed rubric scoring
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
  LATE
}

enum Role {
  STUDENT
  INSTRUCTOR    // MVP role — replaces TUTOR
  ZEHNAI_ADMIN  // Platform super-user
  TUTOR         // Legacy — maps to INSTRUCTOR
  ADMIN         // Legacy — maps to ZEHNAI_ADMIN
}

enum UserStatus {
  PENDING_APPROVAL  // Student registered, awaiting instructor approval
  APPROVED          // Active — can access their portal
  REJECTED          // Declined by instructor
}
