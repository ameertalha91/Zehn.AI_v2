{
  "name": "css-ai-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && (npx update-browserslist-db@latest || true) && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "migrate:production": "bash scripts/migrate-production.sh",
    "migrate:interactive": "node scripts/run-migration.js",
    "vercel:setup": "bash scripts/setup-vercel.sh",
    "setup:env": "bash scripts/setup-env.sh",
    "vercel:add-env": "bash scripts/add-vercel-env.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.542.0",
    "next": "14.2.5",
    "openai": "^5.16.0",
    "pdf-parse": "^1.1.1",
    "react": "^18",
    "react-dom": "^18",
    "react-youtube": "^10.1.0",
    "ytdl-core": "^4.11.5",
    "zod": "^3.23.8",
    "tailwindcss": "^3.3.0",
    "postcss": "^8",
    "autoprefixer": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "prisma": "^6.15.0",
    "typescript": "5.4.5"
  }
}